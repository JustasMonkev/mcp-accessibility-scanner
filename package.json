{
	"name": "mcp-accessibility-scanner",
	"version": "2.0.14",
	"mcpName": "io.github.JustasMonkev/mcp-accessibility-scanner",
	"description": "A Model Context Protocol (MCP) server for performing automated accessibility scans of web pages using Playwright and Axe-core",
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"bin": {
		"mcp-accessibility-scanner": "cli.js",
		"mcp-server-playwright": "cli.js"
	},
	"files": [
		"index.js",
		"index.d.ts",
		"config.d.ts",
		"lib/**/*",
		"README.md",
		"LICENSE",
		"NOTICE.md"
	],
	"scripts": {
		"build": "tsgo --project tsconfig.json",
		"docker:build:multiarch": "docker buildx build --platform linux/amd64,linux/arm64 -t ${IMAGE:-ghcr.io/justasmonkev/mcp-accessibility-scanner}:latest -t ${IMAGE:-ghcr.io/justasmonkev/mcp-accessibility-scanner}:$npm_package_version --push .",
		"lint": "eslint . && npm run typecheck",
		"typecheck": "tsgo --noEmit --project tsconfig.json",
		"watch": "tsgo --watch --project tsconfig.json",
		"run-server": "node lib/browserServer.js",
		"clean": "rm -rf lib",
		"npm-publish": "npm run clean && npm run build && npm publish",
		"test": "vitest run",
		"test:docker": "bash ./tests/docker-smoke.sh",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@cfworker/json-schema": "^4.1.1",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"commander": "^14.0.3",
		"debug": "^4.4.3",
		"dotenv": "^17.4.2",
		"mime": "^4.1.0",
		"playwright": "1.61.0",
		"playwright-core": "1.61.0",
		"re2": "^1.24.1",
		"ws": "^8.21.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "1.61.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/chrome": "^0.1.42",
		"@types/debug": "^4.1.13",
		"@types/node": "^25.9.1",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.60.0",
		"@typescript-eslint/parser": "^8.60.0",
		"@typescript-eslint/utils": "^8.60.0",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"@vitest/coverage-v8": "^4.1.7",
		"@vitest/ui": "^4.1.7",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-notice": "^1.0.0",
		"happy-dom": "^20.9.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"keywords": [
		"mcp",
		"accessibility",
		"a11y",
		"wcag",
		"axe-core",
		"playwright",
		"claude",
		"model-context-protocol"
	],
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JustasMonkev/mcp-accessibility-scanner.git"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"overrides": {
		"minimatch": ">=10.2.3",
		"diff": "5.2.2",
		"rollup": "^4.59.0",
		"qs": ">=6.15.2"
	},
	"ts-node": {
		"transpileOnly": true,
		"esm": true
	},
	"allowScripts": {
		"fsevents@2.3.2": true,
		"fsevents@2.3.3": true,
		"re2@1.24.1": true
	}
}
